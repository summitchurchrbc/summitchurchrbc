FROM node:22-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./
COPY cron/live-check.ts cron/
COPY cron/live-check-loop.ts cron/
COPY cron/live-check-schedule.ts cron/
COPY content/youtube.json content/
COPY content/live-check-schedule.json content/

ENV LIVE_STATUS_OUTPUT=/var/live-status/live-status.json

CMD ["npx", "tsx", "cron/live-check-loop.ts"]