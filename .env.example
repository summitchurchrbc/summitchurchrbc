# Optional — YouTube Data API v3 key for reliable live detection.
# Without it, live-check falls back to scraping the /live page.
YOUTUBE_API_KEY=

# Optional — override where live-check writes status JSON.
# Default: public/live-status.json (local) or /var/live-status/live-status.json (Docker)
LIVE_STATUS_OUTPUT=

# Optional — log file path for host crontab install script (local cron only)
YOUTUBE_SYNC_LOG=